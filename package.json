{
  "name": "roblox-shipcheck",
  "version": "0.1.0",
  "description": "Heuristic release checks and smoke tests for Roblox projects via MCP",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "roblox-shipcheck": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "publint": "publint",
    "check": "tsc --noEmit && eslint src/ && prettier --check src/ && publint",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "roblox",
    "roblox-studio",
    "shipcheck",
    "release-readiness",
    "playtesting",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "game-development",
    "developer-tools",
    "testing",
    "compliance",
    "content-maturity",
    "automation",
    "open-cloud",
    "typescript"
  ],
  "author": "zaferdace",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zaferdace/roblox-shipcheck.git"
  },
  "bugs": { "url": "https://github.com/zaferdace/roblox-shipcheck/issues" },
  "homepage": "https://github.com/zaferdace/roblox-shipcheck#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2"
  }
}
